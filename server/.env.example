# Environment Configuration

# App
APP_NAME=Redspot
APP_VERSION=0.1.0
DEBUG=false

# Server
HOST=127.0.0.1
PORT=8000

# CORS Origins (JSON array)
CORS_ORIGINS=["*"]

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=redspot
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DATABASE=redspot
POSTGRES_USER=redspot
POSTGRES_PASSWORD=redspot

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=redspot_events

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440